# Backend environment (copy to server/.env — do not commit server/.env)
PORT=5001

# Comma-separated frontend origins for CORS
APP_URL=http://localhost:5173,http://localhost:5174

# SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=restaurant_management
DB_USER=sa
DB_PASSWORD=YourStrong@Pass123
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# SMTP (Gmail app password — sender only; OTP goes to user's email)
# Use server/.env for backend secrets. Root .env is frontend-only (VITE_*).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender_gmail@gmail.com
SMTP_PASS=your_google_app_password_without_spaces
# Optional aliases also supported: EMAIL_USER, EMAIL_PASS, EMAIL_FROM
# SMTP_FROM=your_sender_gmail@gmail.com

# Google OAuth (same client ID as frontend)
# Authorized JavaScript origins:
#   http://localhost:5173
#   http://localhost:5174
GOOGLE_CLIENT_ID=your_google_client_id_here
